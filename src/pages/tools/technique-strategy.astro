---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProcedureCard from '../../components/ProcedureCard.astro';

const strategies = [
  {
    title: 'Aneurysm Coiling',
    description: 'Simple coiling, balloon assist, stent assist, neck-bridging concepts, and recurrence grading.',
    icon: '🌀',
    href: '/tools/technique-strategy',
    tag: 'Aneurysm',
  },
  {
    title: 'Device Compatibility',
    description: 'Check guide, intermediate, microcatheter, balloon, stent, and embolic compatibility.',
    icon: '🔧',
    href: '/tools/devices',
    tag: 'Specs',
  },
  {
    title: 'Prediction Screens',
    description: 'Move from disease risk screen to treatment planning and device selection.',
    icon: '📈',
    href: '/tools/devices',
    tag: 'Planning',
  },
];
---

<BaseLayout title="Technique & Strategy">
  <section class="bg-white px-4 py-12">
    <div class="mx-auto max-w-6xl">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-primary-700">Clinical module</p>
      <h1 class="mb-4 text-3xl font-bold text-gray-900 md:text-4xl">Technique & Strategy</h1>
      <p class="mb-8 max-w-3xl text-lg text-gray-700">
        Treatment strategy workspace for aneurysm coiling, adjunctive device selection, compatibility checks, and disease-specific planning.
      </p>
      <div class="grid gap-6 md:grid-cols-3">
        {strategies.map((item) => <ProcedureCard {...item} />)}
      </div>
    </div>
  </section>
</BaseLayout>

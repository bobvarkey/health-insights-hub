---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { trials, categories } from '../../data/trials';

const trialsCount = trials.length;
const publishedCount = trials.filter(t => t.status === 'published').length;
const ongoingCount = trials.filter(t => t.status === 'ongoing').length;
---

<BaseLayout title="Clinical Trials Reference" description="Comprehensive guide to major interventional neurology trials">
  <div class="max-w-7xl mx-auto px-4 py-8 md:py-12">
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-3xl md:text-4xl font-bold text-primary mb-4">Clinical Trials Reference</h1>
      <p class="text-lg text-text-secondary mb-8 max-w-3xl">
        A comprehensive guide to landmark and emerging clinical trials in interventional neurology. Based on the LINNC-Trials-book-2025 database, covering stroke, aneurysm, AVM, and other neuroendovascular indications.
      </p>

      <!-- Stats -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
        <div class="bg-accent/10 border border-accent rounded-lg p-4">
          <div class="text-2xl font-bold text-accent">{trialsCount}</div>
          <div class="text-sm text-text-secondary">Total Trials</div>
        </div>
        <div class="bg-success/10 border border-success rounded-lg p-4">
          <div class="text-2xl font-bold text-success">{publishedCount}</div>
          <div class="text-sm text-text-secondary">Published</div>
        </div>
        <div class="bg-warning/10 border border-warning rounded-lg p-4">
          <div class="text-2xl font-bold text-warning">{ongoingCount}</div>
          <div class="text-sm text-text-secondary">Ongoing</div>
        </div>
      </div>
    </div>

    <!-- Trials by Category -->
    <div class="space-y-12">
      {categories.map((category) => {
        const categoryTrials = trials.filter(t => t.category === category);
        return (
          <section>
            <h2 class="text-2xl font-bold text-primary mb-6">{category}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {categoryTrials.map((trial) => (
                <div class="bg-white border border-border rounded-lg p-6 hover:shadow-lg transition-shadow">
                  <!-- Header -->
                  <div class="flex items-start justify-between mb-4">
                    <div>
                      <h3 class="text-lg font-bold text-primary">{trial.name}</h3>
                      <p class="text-sm text-text-secondary mt-1">{trial.indication}</p>
                    </div>
                    <span class={`text-xs font-medium px-2 py-1 rounded whitespace-nowrap ml-2 ${
                      trial.status === 'published'
                        ? 'bg-success/10 text-success'
                        : trial.status === 'ongoing'
                        ? 'bg-warning/10 text-warning'
                        : 'bg-bg-surface text-text-secondary'
                    }`}>
                      {trial.status === 'published' ? 'Published' : trial.status === 'ongoing' ? 'Ongoing' : 'Unpublished'}
                    </span>
                  </div>

                  <!-- Summary -->
                  <p class="text-sm text-text-secondary mb-4">{trial.summary}</p>

                  <!-- Key Findings -->
                  {trial.keyFindings && trial.keyFindings.length > 0 && (
                    <div class="mb-4">
                      <p class="text-sm font-semibold text-primary mb-2">Key Findings:</p>
                      <ul class="text-sm text-text-secondary space-y-1">
                        {trial.keyFindings.map((finding) => (
                          <li class="flex items-start gap-2">
                            <span class="text-accent">•</span>
                            <span>{finding}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}

                  <!-- Tags -->
                  {trial.relevantFor && trial.relevantFor.length > 0 && (
                    <div class="flex flex-wrap gap-2 pt-4 border-t border-border">
                      {trial.relevantFor.map((tag) => (
                        <span class="text-xs px-2 py-1 bg-bg-surface text-text-secondary rounded">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          </section>
        );
      })}
    </div>

    <!-- Additional Info -->
    <div class="mt-12 bg-bg-surface border-l-4 border-accent p-6 rounded">
      <h3 class="font-bold text-primary mb-2">About This Database</h3>
      <p class="text-sm text-text-secondary mb-3">
        This trials reference is based on the LINNC-Trials-book-2025, a comprehensive database of clinical trials relevant to interventional neurology.
      </p>
      <p class="text-sm text-text-secondary">
        Trials are organized by clinical indication and include published landmark studies, ongoing trials, and emerging research. Use this as a reference to understand key evidence and trial design for various neuroendovascular conditions.
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  section {
    scroll-margin-top: 2rem;
  }
</style>

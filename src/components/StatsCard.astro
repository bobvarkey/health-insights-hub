---
export interface Props {
  number: string;
  label: string;
}

const { number, label } = Astro.props;
---

<div class="bg-white border border-gray-200 rounded-lg p-6 text-center hover:shadow-lg transition-shadow">
  <div class="text-3xl font-bold text-primary-600 mb-2">{number}</div>
  <div class="text-sm font-medium text-gray-600">{label}</div>
</div>

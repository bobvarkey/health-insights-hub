---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-50 border-t border-gray-200 mt-16 pt-12 pb-20 md:pb-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Footer Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <!-- Brand Info -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">⚕️</span>
          <h3 class="font-semibold text-gray-900">Interventional Neuro</h3>
        </div>
        <p class="text-gray-600 text-sm">
          A modern clinical education platform for interventional neurology procedures and best practices.
        </p>
      </div>

      <!-- Tools Links -->
      <div>
        <h4 class="font-semibold text-gray-900 mb-4">Tools</h4>
        <ul class="space-y-2">
          <li>
            <a href="/tools" class="text-gray-600 hover:text-accent transition-colors text-sm">
              Platform Modules
            </a>
          </li>
          <li>
            <a href="/tools/devices" class="text-gray-600 hover:text-accent transition-colors text-sm">
              Device Compatibility
            </a>
          </li>
          <li>
            <a href="/tools/procedural-checklists" class="text-gray-600 hover:text-accent transition-colors text-sm">
              Procedure Checklists
            </a>
          </li>
          <li>
            <a href="/learning-resources/clinical-trials" class="text-gray-600 hover:text-accent transition-colors text-sm">
              Trials Reference
            </a>
          </li>
        </ul>
      </div>

      <!-- Learning Links -->
      <div>
        <h4 class="font-semibold text-gray-900 mb-4">Learning</h4>
        <ul class="space-y-2">
          <li>
            <a href="/clinical-scenarios" class="text-gray-600 hover:text-accent transition-colors text-sm">
              Clinical Scenarios
            </a>
          </li>
          <li>
            <a href="/tools/technique-strategy" class="text-gray-600 hover:text-accent transition-colors text-sm">
              Interactive Modules
            </a>
          </li>
          <li>
            <a href="/learning-resources" class="text-gray-600 hover:text-accent transition-colors text-sm">
              Best Practices
            </a>
          </li>
          <li>
            <a href="/learning-resources" class="text-gray-600 hover:text-accent transition-colors text-sm">
              Guidelines
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal Links -->
      <div>
        <h4 class="font-semibold text-gray-900 mb-4">Legal</h4>
        <ul class="space-y-2">
          <li>
            <a href="/about" class="text-gray-600 hover:text-accent transition-colors text-sm">
              Privacy Policy
            </a>
          </li>
          <li>
            <a href="/about" class="text-gray-600 hover:text-accent transition-colors text-sm">
              Terms of Use
            </a>
          </li>
          <li>
            <a href="/about" class="text-gray-600 hover:text-accent transition-colors text-sm">
              Disclaimer
            </a>
          </li>
          <li>
            <a href="/about" class="text-gray-600 hover:text-accent transition-colors text-sm">
              Contact
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright Notice -->
    <div class="border-t border-gray-200 pt-8">
      <p class="text-center text-gray-600 text-sm">
        &copy; {currentYear} Interventional Neuro Platform. All rights reserved.
      </p>
    </div>
  </div>
</footer>
